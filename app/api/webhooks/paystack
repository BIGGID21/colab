// POST: This is what Paystack hits when a payment is made
export async function POST(req) {
  // Master client to bypass security rules
  const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL,
    process.env.SUPABASE_SERVICE_ROLE_KEY 
  );

  try {
    const body = await req.json();
    console.log("🔔 Webhook Event:", body.event);

    if (body.event === 'charge.success') {
      const userId = body.data?.metadata?.userId;
      
      console.log("👤 Processing payment for User ID:", userId);

      if (userId) {
        // The update command
        const { data, error } = await supabase
          .from('profiles')
          .update({ is_verified: true })
          .eq('id', userId)
          .select();

        if (error) {
          console.error("❌ Database Error:", error.message);
          return new Response('DB Error', { status: 500 });
        }

        if (data && data.length > 0) {
          console.log("🏆 SUCCESS: Profile updated to PRO!");
          return new Response('Verified', { status: 200 });
        } else {
          console.warn("⚠️ User ID not found in database.");
          return new Response('User Not Found', { status: 404 });
        }
      }
    }

    return new Response('Acknowledged', { status: 200 });
  } catch (err) {
    console.error("💀 Webhook Crash:", err.message);
    return new Response('Error', { status: 500 });
  }
}
