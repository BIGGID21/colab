import { createClient } from '@supabase/supabase-js';

export async function POST(req) {
  // We use the SERVICE ROLE KEY here because the webhook is a "system" process, 
  // not a logged-in user. This key has permission to update any profile.
  const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL,
    process.env.SUPABASE_SERVICE_ROLE_KEY 
  );

  try {
    const body = await req.json();

    // Check if the event is a successful payment
    if (body.event === 'charge.success') {
      const userId = body.data.metadata?.userId;
      
      console.log("🔔 WEBHOOK: Payment success received for User ID:", userId);

      if (userId) {
        // Update the user's profile to verified
        const { error } = await supabase
          .from('profiles')
          .update({ is_verified: true })
          .eq('id', userId);

        if (error) {
          console.error("❌ WEBHOOK: Supabase update failed:", error.message);
          return new Response('Database Update Failed', { status: 500 });
        }
        
        console.log("✅ WEBHOOK: Database updated successfully! User is now PRO.");
      } else {
        console.warn("⚠️ WEBHOOK: No User ID found in metadata.");
      }
    }

    return new Response('Webhook Received', { status: 200 });
  } catch (err) {
    console.error("💀 WEBHOOK: Crashed during processing:", err.message);
    return new Response('Webhook Error', { status: 500 });
  }
}
