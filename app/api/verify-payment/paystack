export const dynamic = 'force-dynamic';

import { createClient } from '@supabase/supabase-js';

// GET: Testing only (You already proved this works!)
export async function GET() {
  return new Response("✅ VERIFY ROUTE IS ONLINE", { status: 200 });
}

// POST: The actual Paystack logic
export async function POST(req) {
  // Initialize Supabase with Service Role Key to bypass RLS
  const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL,
    process.env.SUPABASE_SERVICE_ROLE_KEY 
  );

  try {
    const body = await req.json();
    console.log("🔔 WEBHOOK RECEIVED. Event Type:", body.event);

    if (body.event === 'charge.success') {
      const userId = body.data?.metadata?.userId;
      
      console.log("👤 ATTEMPTING TO VERIFY USER:", userId);

      if (userId) {
        const { data, error } = await supabase
          .from('profiles')
          .update({ is_verified: true })
          .eq('id', userId)
          .select(); // We select to confirm it actually found someone

        if (error) {
          console.error("❌ SUPABASE UPDATE ERROR:", error.message);
          return new Response('Database Error', { status: 500 });
        }

        if (data && data.length > 0) {
          console.log("🏆 SUCCESS! User found and updated in database.");
          return new Response('User Verified Successfully', { status: 200 });
        } else {
          console.warn("⚠️ WARNING: User ID not found in profiles table.");
          return new Response('User Not Found', { status: 404 });
        }
      }
    }

    return new Response('Event Acknowledged', { status: 200 });
  } catch (err) {
    console.error("💀 CRITICAL ERROR:", err.message);
    return new Response('Internal Server Error', { status: 500 });
  }
}